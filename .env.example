GRAPHRAG_LLM_PROVIDER=ollama
GRAPHRAG_GENERATION_MODEL=qwen3:14b
GRAPHRAG_PLANNER_MODEL=qwen3:14b
GRAPHRAG_EMBEDDING_MODEL=mxbai-embed-large
GRAPHRAG_EMBEDDING_DIMENSIONS=1024
OLLAMA_BASE_URL=http://localhost:11434

# Set only when GRAPHRAG_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GRAPHRAG_VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cyber_grc_chunks

GRAPHRAG_GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

GRAPHRAG_TOP_K=12
GRAPHRAG_DEBUG=false
GRAPHRAG_HOST=127.0.0.1
GRAPHRAG_PORT=8000
